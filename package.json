{
  "name": "@allstak/react",
  "version": "0.2.1",
  "description": "AllStak React SDK — standalone error tracking, breadcrumbs, ErrorBoundary, useAllStak hook, and withAllStakProfiler HOC. No @allstak/* runtime dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AllStak/allstak-react.git"
  },
  "homepage": "https://allstak.sa",
  "bugs": {
    "url": "https://github.com/AllStak/allstak-react/issues"
  },
  "keywords": [
    "allstak",
    "observability",
    "react",
    "error-tracking",
    "apm"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --platform browser --external react --external react-dom",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 test/*.test.mjs"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "jsdom": "^29.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
